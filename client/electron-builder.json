{
  "appId": "com.proxyness.app",
  "productName": "Proxyness",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "build/*.png"
  ],
  "extraResources": [
    {
      "from": "resources/",
      "to": "resources/",
      "filter": ["daemon-*", "helper-*", "wintun.dll", "seed_sites.json"]
    },
    {
      "from": "../extension/",
      "to": "extension/"
    }
  ],
  "publish": {
    "provider": "github",
    "owner": "ilyasmurov",
    "repo": "proxyness"
  },
  "mac": {
    "target": ["pkg"],
    "icon": null
  },
  "pkg": {
    "scripts": "pkg-scripts",
    "installLocation": "/Applications",
    "isRelocatable": false
  },
  "win": {
    "target": ["nsis"],
    "icon": null,
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": true,
    "uninstallDisplayName": "Proxyness",
    "artifactName": "${productName}-Setup-${version}.${ext}"
  }
}
