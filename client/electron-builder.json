{
  "appId": "com.smurov.proxy",
  "productName": "SmurovProxy",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "build/*.png"
  ],
  "extraResources": [
    {
      "from": "resources/",
      "to": "resources/",
      "filter": ["daemon-*", "helper-*", "wintun.dll"]
    }
  ],
  "publish": {
    "provider": "github",
    "owner": "ilyasmurov",
    "repo": "smurov-proxy"
  },
  "mac": {
    "target": ["pkg"],
    "icon": null
  },
  "pkg": {
    "scripts": "pkg-scripts",
    "installLocation": "/Applications",
    "isRelocatable": false
  },
  "win": {
    "target": ["nsis"],
    "icon": null,
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": true,
    "uninstallDisplayName": "SmurovProxy"
  }
}
