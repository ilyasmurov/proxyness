{
  "appId": "com.smurov.proxy",
  "productName": "SmurovProxy",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/",
      "to": "resources/",
      "filter": ["daemon-*"]
    }
  ],
  "publish": {
    "provider": "github",
    "owner": "ilyasmurov",
    "repo": "smurov-proxy"
  },
  "mac": {
    "target": ["dmg"],
    "icon": null
  },
  "win": {
    "target": ["nsis"],
    "icon": null
  }
}
